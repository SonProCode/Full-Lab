RABBITMQ_USER=lab
RABBITMQ_PASSWORD=lab
RATE_LIMIT_PER_MINUTE=10
PREFETCH_COUNT=10
MAX_RETRIES=3
RETRY_DELAY_MS=3000
ES_JAVA_OPTS=-Xms512m -Xmx512m
LS_JAVA_OPTS=-Xms256m -Xmx256m
# Override these when another local lab already owns a default port.
API_PORT=8000
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
